# Microsoft Ads API Configuration
# ================================
# This file is a template. Copy it to .env and fill in your values.
# NEVER commit .env to version control.

# Microsoft Ads Customer ID
# Find in Microsoft Ads: Settings > Account > Account Number
MICROSOFT_ADS_CUSTOMER_ID=your-customer-id

# Microsoft Ads Account ID
# Find in Microsoft Ads: Settings > Account
MICROSOFT_ADS_ACCOUNT_ID=your-account-id

# Microsoft Ads Developer Token
# Apply at: https://learn.microsoft.com/en-us/advertising/guides/get-started
MICROSOFT_ADS_DEVELOPER_TOKEN=your-developer-token

# Azure AD OAuth credentials
# Register an app at: https://portal.azure.com > App registrations
MICROSOFT_ADS_CLIENT_ID=your-client-id
MICROSOFT_ADS_CLIENT_SECRET=your-client-secret

# How to set up:
# 1. Register an application in Azure AD (portal.azure.com)
# 2. Add Microsoft Advertising API permissions
# 3. Generate a client secret
# 4. Apply for a developer token at Microsoft Advertising
# 5. Copy this file to .env and fill in your values
#
# NEVER commit .env or credentials to version control!
