# Google Ads API Configuration
# ============================
# This file is a template. Copy it to .env and fill in your values.
# NEVER commit .env to version control.

# Google Ads Customer ID (10-digit number, no dashes)
# Find in Google Ads: top-right corner of the UI
GOOGLE_ADS_CUSTOMER_ID=1234567890

# Google Ads Developer Token
# Apply at: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token-here

# Path to Google OAuth2 credentials JSON file
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client
GOOGLE_APPLICATION_CREDENTIALS=/path/to/oauth-credentials.json

# Google Ads Login Customer ID (MCC ID, if using a manager account)
# Leave blank if accessing a single account directly
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# How to set up:
# 1. Go to Google Cloud Console (console.cloud.google.com)
# 2. Create a project (or select existing)
# 3. Enable the Google Ads API
# 4. Create OAuth 2.0 credentials (Desktop app type)
# 5. Download the credentials JSON file
# 6. Apply for a developer token at the Google Ads API Center
# 7. Copy this file to .env and fill in your values
#
# NEVER commit .env or credentials JSON to version control!
