# Braze API Configuration
# =======================
# This file is a template. Copy it to .env and fill in your values.
# NEVER commit .env to version control.

# Braze REST API Key
# Dashboard > Settings > API Keys > Create New API Key
BRAZE_REST_API_KEY=your-rest-api-key-here

# Braze REST API Endpoint (depends on your instance)
# US-01: https://rest.iad-01.braze.com
# US-02: https://rest.iad-02.braze.com
# EU-01: https://rest.fra-01.braze.eu
BRAZE_REST_ENDPOINT=https://rest.iad-01.braze.com

# Braze App Group ID (for SDK and user data)
# Dashboard > Settings > App Settings
BRAZE_APP_GROUP_ID=your-app-group-id-here

# How to set up:
# 1. Log in to your Braze Dashboard
# 2. Go to Settings > API Keys
# 3. Create a new API key with appropriate permissions
# 4. Note your REST API endpoint (varies by instance/cluster)
# 5. Copy this file to .env and fill in your values
#
# NEVER commit .env or API keys to version control!
