{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event-spec.schema.json",
  "title": "GA4 Event Specification",
  "description": "Machine-readable GA4 event spec for analytics agent pipeline comparison",
  "type": "object",
  "required": ["version", "client", "ga4_property", "last_updated", "event_groups"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "client": {
      "type": "string",
      "description": "Client slug matching client config"
    },
    "ga4_property": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "GA4 property ID"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date (YYYY-MM-DD)"
    },
    "event_groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event_group" }
    },
    "deprecated_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/deprecated_event" }
    },
    "custom_dimensions_needed": {
      "type": "array",
      "items": { "$ref": "#/$defs/custom_dimension" }
    }
  },
  "$defs": {
    "event_group": {
      "type": "object",
      "required": ["group_id", "group_name", "phase", "description", "events"],
      "additionalProperties": false,
      "properties": {
        "group_id": { "type": "string" },
        "group_name": { "type": "string" },
        "phase": { "type": "integer", "minimum": 1 },
        "description": { "type": "string" },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/event" }
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["name", "type", "ga4_type", "description", "fires_on", "required_params", "gtm", "status", "priority"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["custom", "ga4_recommended"]
        },
        "ga4_type": {
          "type": "string",
          "enum": ["custom", "recommended"]
        },
        "description": { "type": "string" },
        "fires_on": { "type": "string" },
        "required_params": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gtm": { "$ref": "#/$defs/gtm_config" },
        "replaces": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "status": {
          "type": "string",
          "enum": ["not_implemented", "in_workspace", "published"]
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        }
      }
    },
    "gtm_config": {
      "type": "object",
      "required": ["tag_type", "trigger_type", "requires_datalayer", "datalayer_variables"],
      "additionalProperties": false,
      "properties": {
        "tag_type": { "type": "string" },
        "trigger_type": {
          "type": "string",
          "enum": [
            "CUSTOM_EVENT",
            "PAGEVIEW",
            "DOM_READY",
            "WINDOW_LOADED",
            "CLICK",
            "LINK_CLICK",
            "FORM_SUBMISSION"
          ]
        },
        "trigger_event_name": { "type": "string" },
        "trigger_filter": {
          "type": "object",
          "properties": {
            "field": { "type": "string" },
            "operator": { "type": "string" },
            "value": { "type": "string" }
          },
          "required": ["field", "operator", "value"],
          "additionalProperties": false
        },
        "requires_datalayer": { "type": "boolean" },
        "datalayer_variables": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "deprecated_event": {
      "type": "object",
      "required": ["name", "replaced_by", "deprecation_status"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "replaced_by": { "type": "string" },
        "deprecation_status": {
          "type": "string",
          "enum": ["pending", "deprecated", "removed"]
        }
      }
    },
    "custom_dimension": {
      "type": "object",
      "required": ["name", "scope", "description"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "scope": {
          "type": "string",
          "enum": ["event", "user"]
        },
        "description": { "type": "string" }
      }
    }
  }
}
